{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "emotion_steering_lab/schemas/steering_profile.schema.json",
  "title": "Steering Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile_id",
    "created_at",
    "model_id",
    "probe_name",
    "layers",
    "alpha",
    "scope",
    "enabled"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "profile_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "model_id": { "type": "string", "minLength": 1 },
    "probe_name": { "type": "string", "minLength": 1 },
    "layers": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "integer", "minimum": 0 }
    },
    "alpha": { "type": "number", "minimum": -1, "maximum": 1 },
    "scope": { "type": "string", "enum": ["full_suite", "failures_only"] },
    "enabled": { "type": "boolean" }
  }
}
